# Uncomment this line to define a global platform for your project
platform :ios, '15.5'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# Flutter flavors create build configurations named "Debug-<flavor>", "Release-<flavor>", etc.
project 'Runner', {
  'Debug-dev' => :debug,
  'Debug-prod' => :debug,
  'Profile-dev' => :release,
  'Profile-prod' => :release,
  'Release-dev' => :release,
  'Release-prod' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  # ML Kit pod identifiers that lack arm64-simulator slices.
  mlkit_identifiers = ['GoogleMLKit', 'MLKit', 'google_mlkit']

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    is_mlkit = mlkit_identifiers.any? { |id| target.name.include?(id) }

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'

      # For dev (simulator) builds, skip compiling ML Kit pods entirely
      # by excluding all architectures.
      if is_mlkit && config.name.downcase.include?('-dev')
        config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64 x86_64'
        config.build_settings['EXCLUDED_ARCHS[sdk=iphoneos*]'] = 'arm64'
      end
    end
  end

  # Apply deployment target to Runner project targets
  installer.aggregate_targets.each do |target|
    target.user_project.targets.each do |user_target|
      user_target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'
      end
    end
    target.user_project.save
  end

  # Patch the Pods-Runner xcconfig files for dev configurations to remove
  # ML Kit framework linker references. This prevents "framework not found"
  # errors when ML Kit pods are excluded from simulator builds.
  pods_support = File.join(__dir__, 'Pods', 'Target Support Files')
  ['Pods-Runner', 'Pods-RunnerTests'].each do |pod_target|
    target_dir = File.join(pods_support, pod_target)
    next unless File.directory?(target_dir)

    Dir.glob(File.join(target_dir, '*-dev.xcconfig')).each do |xcconfig_path|
      content = File.read(xcconfig_path)
      # Remove -framework "GoogleMLKit..." / -framework "MLKit..." entries
      content.gsub!(/-framework\s+"(GoogleMLKit|MLKit|google_mlkit)[^"]*"\s*/, '')
      # Remove -l"google_mlkit..." linker flags
      content.gsub!(/-l"(google_mlkit)[^"]*"\s*/, '')
      File.write(xcconfig_path, content)
    end
  end
end
